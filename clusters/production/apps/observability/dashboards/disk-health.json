{
  "uid": "disk-health",
  "title": "Disk Health (PVE hosts — SMART)",
  "tags": ["disk", "smart", "proxmox"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "SMART health",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        { "expr": "smartctl_device_smart_status", "legendFormat": "{{node}} {{device}}", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "none", "orientation": "horizontal", "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Temperature",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "max by (node, device) (smartctl_device_temperature)", "legendFormat": "{{node}} {{device}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius", "decimals": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 55 }, { "color": "red", "value": 65 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Endurance used (NVMe % / SSD wear-leveling value→0)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "smartctl_device_percentage_used", "legendFormat": "{{node}} {{device}} (NVMe %used)", "refId": "A" },
        { "expr": "smartctl_device_attribute{attribute_id=~\"173|177|230|233\",attribute_value_type=\"value\"}", "legendFormat": "{{node}} {{device}} ({{attribute_name}})", "refId": "B" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "orientation": "horizontal", "textMode": "value_and_name"
      },
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Bad sectors (reallocated / pending / uncorrectable / CRC — raw)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        { "expr": "smartctl_device_attribute{attribute_id=~\"5|197|198|199\",attribute_value_type=\"raw\"}", "legendFormat": "{{node}} {{device}} {{attribute_name}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "auto" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Lifetime data written",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        { "expr": "smartctl_device_bytes_written", "legendFormat": "{{node}} {{device}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" }
        },
        "overrides": []
      }
    }
  ]
}
