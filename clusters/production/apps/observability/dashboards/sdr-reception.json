    "sdr",
    "edge-sdr",
    "adsb",
    "ais"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
