{
  "uid": "edge-security",
  "title": "Edge Security (CrowdSec + NAXSI)",
  "tags": ["security", "crowdsec", "naxsi", "edge"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active bans (CrowdSec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(cs_active_decisions)",
          "legendFormat": "active bans",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "IPs banned in firewall",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(fw_bouncer_banned_ips)",
          "legendFormat": "banned IPs",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Scenario triggers (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(cs_bucket_overflowed_total[24h]))",
          "legendFormat": "triggers",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 25 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "NAXSI events (24h)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"opnsense\"} |= `NAXSI_FMT` [24h]))",
          "queryType": "instant",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CrowdSec scenario triggers (bucket overflows)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (name) (increase(cs_bucket_overflowed_total[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Firewall drops (bouncer)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum by (origin) (rate(fw_bouncer_dropped_packets[$__rate_interval]))",
          "legendFormat": "{{origin}} pkt/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "NAXSI events over time (OPNsense)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"opnsense\"} |= `NAXSI_FMT` [$__auto]))",
          "legendFormat": "NAXSI events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Active decisions by origin",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "sum by (origin) (cs_active_decisions)",
          "legendFormat": "{{origin}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top NAXSI source IPs (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, sum by (src_ip) (count_over_time({service_name=\"opnsense\"} |= `NAXSI_FMT` | regexp `ip=(?P<src_ip>[^&]+)` [$__range])))",
          "queryType": "instant",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top NAXSI rule IDs (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, sum by (rule_id) (count_over_time({service_name=\"opnsense\"} |= `NAXSI_FMT` | regexp `id0=(?P<rule_id>[0-9]+)` [$__range])))",
          "queryType": "instant",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Top targeted URIs (range)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, sum by (uri) (count_over_time({service_name=\"opnsense\"} |= `NAXSI_FMT` | regexp `uri=(?P<uri>[^&]+)` [$__range])))",
          "queryType": "instant",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "fieldConfig": { "defaults": { "decimals": 0 }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "logs",
      "title": "CrowdSec log (edge VPS)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 33 },
      "targets": [{ "expr": "{job=\"crowdsec\"}", "refId": "A" }],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "id": 13,
      "type": "logs",
      "title": "NAXSI raw events (OPNsense)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 33 },
      "targets": [
        { "expr": "{service_name=\"opnsense\"} |= `NAXSI`", "refId": "A" }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ]
}
