      "type": "shell",
      "command": "pwsh -NoProfile -File \"${workspaceFolder}/.vscode/print-test-tier-creds.ps1\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true,
