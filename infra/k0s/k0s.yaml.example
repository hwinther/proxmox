apiVersion: k0s.k0sproject.io/v1beta1
kind: ClusterConfig
metadata:
  name: k0s
  namespace: kube-system
spec:
  api:
    # Each controller sets its own LAN IP here (the address this apiserver advertises).
    address: 10.10.20.101
    ca:
      certificatesExpireAfter: 8760h0m0s
      expiresAfter: 87600h0m0s
    # Required when kube-proxy is disabled (e.g. Cilium kube-proxy replacement): the API
    # server cannot reach Service ClusterIPs for aggregation discovery. Without this,
    # APIServices such as metrics.k8s.io and Kubescape storage (spdx.softwarecomposition.*)
    # stay FailedDiscoveryCheck / 503 from the API. See cilium-k0s-setup.md § Aggregated APIs.
    extraArgs:
      enable-aggregator-routing: "true"
      # OIDC for Headlamp (Authelia as IdP): issuer must match JWT `iss` and Headlamp `issuerURL` (https://auth.wsh.no).
      # Controllers need outbound HTTPS to this host for JWKS/discovery. Uncomment when DNS/TLS for auth.wsh.no is live.
      oidc-issuer-url: https://auth.wsh.no
      oidc-client-id: headlamp
      oidc-username-claim: preferred_username
      # Requires `groups` (and username claim) in the ID token — see Authelia `claims_policies` for client `headlamp`
      # in `clusters/production/apps/authelia-production/authelia-helmrelease.yaml`.
      oidc-groups-claim: groups
      # If issuer TLS is not in the controller image default CA bundle, add a PEM path on the controller host:
      # oidc-ca-file: /etc/k0s/ssl/auth-wsh-no-ca.pem
    k0sApiPort: 9443
    port: 6443
  controllerManager: {}
  extensions:
    helm:
      concurrencyLevel: 5
      charts:
      - chartname: cilium/cilium
        name: cilium
        namespace: kube-system
        version: "1.19.2"
        values: |
          # Identity for Hubble TLS: SANs are *.<name>.hubble-grpc.cilium.io. Keep stable
          # or regenerate Hubble TLS secrets after changing (relay checks this hostname).
          cluster:
            name: default
          kubeProxyReplacement: true
          # With nodeLocalLoadBalancing enabled, each node (including workers) has a local
          # Envoy on apiServerBindPort (default 7443) → 127.0.0.1:7443 is correct everywhere.
          # Without that, workers need a real controller IP/VIP:6443, not loopback.
          # On a single-controller cluster you can use the controller's LAN IP directly instead.
          k8sServiceHost: 127.0.0.1
          k8sServicePort: 7443
          ipam:
            mode: kubernetes
          routingMode: tunnel
          tunnelProtocol: vxlan
          hubble:
            enabled: true
            relay:
              enabled: true
              peerService:
                internalTrafficPolicy: Cluster
            ui:
              enabled: true
            tls:
              enabled: true
              auto:
                enabled: true
                method: helm
          # Raspberry Pi edge nodes use taint node-type=edge-sdr:NoSchedule (see
          # raspberry-pi-worker.md). Cilium's chart default is tolerations: [{ operator: Exists }],
          # which schedules on any tainted node. Keep that (or an explicit edge-sdr entry) if you
          # change tolerations here — otherwise cilium-agent may stay Pending on Pis.
          tolerations:
            - operator: Exists
      repositories:
      - name: cilium
        url: https://helm.cilium.io
  installConfig:
    users:
      etcdUser: etcd
      kineUser: kube-apiserver
      konnectivityUser: konnectivity-server
      kubeAPIserverUser: kube-apiserver
      kubeSchedulerUser: kube-scheduler
  konnectivity:
    adminPort: 8133
    agentPort: 8132
  network:
    clusterDomain: cluster.local
    dualStack:
      enabled: false
    kubeProxy:
      disabled: true
      iptables:
        minSyncPeriod: 0s
        syncPeriod: 0s
      ipvs:
        minSyncPeriod: 0s
        syncPeriod: 0s
        tcpFinTimeout: 0s
        tcpTimeout: 0s
        udpTimeout: 0s
      metricsBindAddress: 0.0.0.0:10249
      mode: iptables
      nftables:
        minSyncPeriod: 0s
        syncPeriod: 0s
    kuberouter:
      autoMTU: true
      hairpin: Enabled
      metricsPort: 8080
    # HA (multi-controller): MUST be enabled. Without this, k0s picks ONE controller IP for
    # konnectivity-agent --proxy-server-host, so agents only connect to that server. The other
    # controllers' konnectivity-servers have zero agents → apiserver calls through them
    # (exec, logs, admission webhooks, aggregated APIs) fail with "No agent available".
    # Envoy on each node load-balances to ALL controllers for both API (7443) and Konnectivity
    # (7132). Cilium k8sServiceHost should then point to 127.0.0.1:7443.
    nodeLocalLoadBalancing:
      enabled: true
      envoyProxy:
        apiServerBindPort: 7443
        konnectivityServerBindPort: 7132
      type: EnvoyProxy
    podCIDR: 10.244.0.0/16
    provider: custom
    serviceCIDR: 10.96.0.0/12
  scheduler: {}
  storage:
    etcd:
      ca:
        certificatesExpireAfter: 8760h0m0s
        expiresAfter: 87600h0m0s
      peerAddress: 10.10.20.101
    type: etcd
  telemetry:
    enabled: false
