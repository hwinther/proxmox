apiVersion: k0s.k0sproject.io/v1beta1
kind: ClusterConfig
metadata:
  name: k0s
  namespace: kube-system
spec:
  api:
    # Each controller sets its own LAN IP here (the address this apiserver advertises).
    address: 10.10.20.101
    ca:
      certificatesExpireAfter: 8760h0m0s
      expiresAfter: 87600h0m0s
    # Required when kube-proxy is disabled (e.g. Cilium kube-proxy replacement): the API
    # server cannot reach Service ClusterIPs for aggregation discovery. Without this,
    # APIServices such as metrics.k8s.io and Kubescape storage (spdx.softwarecomposition.*)
    # stay FailedDiscoveryCheck / 503 from the API. See cilium-k0s-setup.md § Aggregated APIs.
    extraArgs:
      enable-aggregator-routing: "true"
      # OIDC for user auth against the kube-apiserver (Authelia as IdP). kube-apiserver's --oidc-client-id
      # is single-valued, so the client_id represents the *cluster API audience*, not any one consumer.
      # Headlamp (and any future OIDC tool) presents a token issued for this client. Issuer is shared
      # (https://auth.wsh.no); client_id differs per cluster:
      #   - production controllers: oidc-client-id: headlamp                  (authelia client `headlamp` — legacy name)
      #   - edge-sdr   controllers: oidc-client-id: kube-apiserver-edge-sdr   (authelia client `kube-apiserver-edge-sdr`)
      # Controllers need outbound HTTPS to auth.wsh.no for JWKS/discovery. Uncomment once DNS/TLS is live.
      oidc-issuer-url: https://auth.wsh.no
      oidc-client-id: headlamp
      oidc-username-claim: preferred_username
      # Requires `groups` (and username claim) in the ID token — see Authelia `claims_policies.headlamp-kube-apiserver`
      # in `clusters/production/apps/authelia-production/authelia-helmrelease.yaml` (used by both clients).
      oidc-groups-claim: groups
      # If issuer TLS is not in the controller image default CA bundle, add a PEM path on the controller host:
      # oidc-ca-file: /etc/k0s/ssl/auth-wsh-no-ca.pem
    k0sApiPort: 9443
    port: 6443
  controllerManager: {}
  extensions:
    helm:
      concurrencyLevel: 5
      charts:
      - chartname: cilium/cilium
        name: cilium
        namespace: kube-system
        version: "1.19.4"
        values: |
          # Identity for Hubble TLS: SANs are *.<name>.hubble-grpc.cilium.io. Keep stable
          # or regenerate Hubble TLS secrets after changing (relay checks this hostname).
          cluster:
            name: default
          kubeProxyReplacement: true
          # eBPF masquerade (replaces the iptables-based masquerade datapath). REQUIRED by
          # egressGateway below — the egress gateway feature SNATs selected pod traffic to the
          # gateway node's egress IP in BPF, so iptables masquerade cannot be in the path. This is
          # the risky change: it moves all node SNAT from iptables to eBPF, so roll it in a
          # maintenance window and verify every app's outbound connectivity afterwards (DNS,
          # PBS backups, OIDC/JWKS to auth.wsh.no, GHCR pulls, external DBs). Requires
          # kubeProxyReplacement: true (above).
          bpf:
            masquerade: true
          # Egress gateway: pins selected pods' outbound traffic to a fixed egress IP on a gateway
          # node, so an upstream firewall can allow that single source IP to reach any ip/port.
          # Bind a workload to it with a CiliumEgressGatewayPolicy (selects pods + destinationCIDRs,
          # names the egressGateway node via nodeSelector + the interface/egressIP). Works with
          # routingMode: tunnel (vxlan). Hard-depends on bpf.masquerade: true above.
          egressGateway:
            enabled: true
          # With nodeLocalLoadBalancing enabled, each node (including workers) has a local
          # Envoy on apiServerBindPort (default 7443) → 127.0.0.1:7443 is correct everywhere.
          # Without that, workers need a real controller IP/VIP:6443, not loopback.
          # On a single-controller cluster you can use the controller's LAN IP directly instead.
          k8sServiceHost: 127.0.0.1
          k8sServicePort: 7443
          ipam:
            mode: kubernetes
          routingMode: tunnel
          tunnelProtocol: vxlan
          # Agent metrics on :9962 (cilium_*). Scraped by the cilium-agent PodMonitor in
          # clusters/production/apps/observability/cilium-podmonitors.yaml.
          prometheus:
            enabled: true
          hubble:
            enabled: true
            relay:
              enabled: true
              peerService:
                internalTrafficPolicy: Cluster
            ui:
              enabled: true
            tls:
              enabled: true
              auto:
                enabled: true
                method: helm
            # Hubble metrics on :9965 (hubble_*). drop carries source/destination namespace
            # labels so NetworkPolicy denials are attributable per namespace (netpol-baseline
            # rollout). Scraped by the same PodMonitor as the agent metrics.
            metrics:
              enabled:
              - dns
              - drop:labelsContext=source_namespace,destination_namespace
              - tcp
              - flow
              - icmp
              - port-distribution
          # Raspberry Pi edge nodes use taint node-type=edge-sdr:NoSchedule (see
          # raspberry-pi-worker.md). Cilium's chart default is tolerations: [{ operator: Exists }],
          # which schedules on any tainted node. Keep that (or an explicit edge-sdr entry) if you
          # change tolerations here — otherwise cilium-agent may stay Pending on Pis.
          tolerations:
            - operator: Exists
      repositories:
      - name: cilium
        url: https://helm.cilium.io
  installConfig:
    users:
      etcdUser: etcd
      kineUser: kube-apiserver
      konnectivityUser: konnectivity-server
      kubeAPIserverUser: kube-apiserver
      kubeSchedulerUser: kube-scheduler
  konnectivity:
    adminPort: 8133
    agentPort: 8132
  network:
    clusterDomain: cluster.local
    dualStack:
      enabled: false
    kubeProxy:
      disabled: true
      iptables:
        minSyncPeriod: 0s
        syncPeriod: 0s
      ipvs:
        minSyncPeriod: 0s
        syncPeriod: 0s
        tcpFinTimeout: 0s
        tcpTimeout: 0s
        udpTimeout: 0s
      metricsBindAddress: 0.0.0.0:10249
      mode: iptables
      nftables:
        minSyncPeriod: 0s
        syncPeriod: 0s
    kuberouter:
      autoMTU: true
      hairpin: Enabled
      metricsPort: 8080
    # HA (multi-controller): MUST be enabled. Without this, k0s picks ONE controller IP for
    # konnectivity-agent --proxy-server-host, so agents only connect to that server. The other
    # controllers' konnectivity-servers have zero agents → apiserver calls through them
    # (exec, logs, admission webhooks, aggregated APIs) fail with "No agent available".
    # Envoy on each node load-balances to ALL controllers for both API (7443) and Konnectivity
    # (7132). Cilium k8sServiceHost should then point to 127.0.0.1:7443.
    nodeLocalLoadBalancing:
      enabled: true
      envoyProxy:
        apiServerBindPort: 7443
        konnectivityServerBindPort: 7132
      type: EnvoyProxy
    podCIDR: 10.244.0.0/16
    provider: custom
    serviceCIDR: 10.96.0.0/12
  scheduler: {}
  # Worker (kubelet) config overrides, selected per node at join time with
  # `k0s install worker --profile <name>`. The `edge-sdr` profile caps per-container log
  # files so chatty pods don't churn the Raspberry Pi SD cards — e.g. konnectivity-agent
  # logs a "Determined server count" line per control-stream reconnect, which bursts to
  # ~1/s during a WAN/VPN blip at the radio-pi site. Defaults (~10Mi x 5 files) are fine on
  # VM workers; workers that join without --profile keep those. See raspberry-pi-worker.md
  # § "kubelet log rotation". Pair with the tmpfs-on-/var/log/pods option there for SD wear.
  workerProfiles:
    - name: edge-sdr
      values:
        # Merged into the node's KubeletConfiguration.
        containerLogMaxSize: "5Mi"
        containerLogMaxFiles: 3
  storage:
    etcd:
      ca:
        certificatesExpireAfter: 8760h0m0s
        expiresAfter: 87600h0m0s
      peerAddress: 10.10.20.101
    type: etcd
  telemetry:
    enabled: false
